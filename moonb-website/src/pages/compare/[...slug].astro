---
import CompareLayout from '../../layouts/CompareLayout.astro';
import { getComparisonPages, getComparisonPage } from '../../lib/sanity';

export async function getStaticPaths() {
  let pages: any[] = [];
  try {
    pages = await getComparisonPages();
  } catch {
    return [];
  }
  return pages.map((page: any) => ({
    params: { slug: page.slug.current },
  }));
}

const { slug } = Astro.params;
let page: any = null;
try {
  page = await getComparisonPage(slug as string);
} catch {
  return Astro.redirect('/');
}

if (!page) return Astro.redirect('/');

const faqs = (page.faqs || []).map((faq: any) => ({
  question: faq.question,
  answer: typeof faq.answer === 'string'
    ? faq.answer
    : (faq.answer || []).map((block: any) => (block.children || []).map((c: any) => c.text).join('')).join(' '),
}));
---

<CompareLayout
  title={page.metaTitle || page.title}
  description={page.metaDescription}
  slug={page.slug.current}
  competitor={page.competitor}
  faqs={faqs}
>
  <section class="section">
    <div class="container container--narrow">
      <h1 style="margin-bottom: var(--space-6);">{page.heroHeading || page.title}</h1>
    </div>
  </section>
</CompareLayout>
