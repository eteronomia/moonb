---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getServicePages } from '../../lib/sanity';

let services: any[] = [];
try {
  services = await getServicePages();
} catch {
  // Sanity not yet populated
}
---

<BaseLayout
  title="Services"
  description="Moonb provides dedicated creative teams for video production, graphic design, motion graphics, animation, and creative strategy."
  breadcrumbs={[{ name: 'Services', url: 'https://www.moonb.io/services' }]}
>
  <section class="section">
    <div class="container">
      <h1 style="margin-bottom: var(--space-6);">Our Services</h1>
      <p style="font-size: var(--text-body-lg); max-width: 600px; margin-bottom: var(--space-12);">
        Enterprise-grade creative production across design, video, motion, and strategy.
      </p>

      {services.length > 0 ? (
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-6);">
          {services.map((service: any) => (
            <a href={`/services/${service.slug.current}`} class="card" style="text-decoration: none;">
              <h3 style="margin-bottom: var(--space-3);">{service.title}</h3>
              <p style="font-size: var(--text-small);">{service.shortDescription || service.metaDescription}</p>
            </a>
          ))}
        </div>
      ) : (
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-6);">
          {['Video Production', 'Graphic Design', 'Motion Graphics', 'Animation', 'Creative Strategy'].map((name) => (
            <div class="card">
              <h3>{name}</h3>
              <p style="margin-top: var(--space-3); color: var(--color-text-muted);">Content coming from Sanity.</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
