---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Book a Demo"
  description="Book a demo with Moonb to learn how a dedicated creative team can support your enterprise design and video production needs."
  breadcrumbs={[{ name: 'Book a Demo', url: 'https://www.moonb.io/book-a-demo' }]}
>
  <section class="section" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="container" style="text-align: center;">
      <h1 style="margin-bottom: var(--space-6);">Book a Demo</h1>
      <p style="font-size: var(--text-body-lg); max-width: 520px; margin-inline: auto; margin-bottom: var(--space-10);">
        See how Moonb's dedicated creative team can become your embedded creative department.
      </p>
      <!-- Cal.com embed will be added here -->
      <div class="glass-card" style="max-width: 640px; margin-inline: auto; padding: var(--space-12); min-height: 400px; display: flex; align-items: center; justify-content: center;">
        <p style="color: var(--color-text-muted);">Cal.com booking widget loads here</p>
      </div>
    </div>
  </section>
</BaseLayout>
