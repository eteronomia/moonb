---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getBlogPosts, getBlogPost } from '../../lib/sanity';

export async function getStaticPaths() {
  let posts: any[] = [];
  try {
    posts = await getBlogPosts();
  } catch {
    return [];
  }
  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;
let post: any = null;
try {
  post = await getBlogPost(slug as string);
} catch {
  return Astro.redirect('/blog');
}

if (!post) return Astro.redirect('/blog');
---

<BlogLayout
  title={post.metaTitle || post.title}
  description={post.metaDescription}
  publishDate={post.publishDate}
  author={post.author}
  slug={post.slug.current}
  noindex={post.noindex}
>
  <p style="color: var(--color-text-muted);">Blog content rendered from Sanity Portable Text.</p>
</BlogLayout>
