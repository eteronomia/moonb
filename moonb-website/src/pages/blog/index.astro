---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogPosts } from '../../lib/sanity';

let posts: any[] = [];
try {
  posts = await getBlogPosts();
} catch {
  // Sanity not yet populated
}
---

<BaseLayout
  title="Blog"
  description="Insights on creative production, video strategy, design trends, and motion graphics from the Moonb team."
  breadcrumbs={[{ name: 'Blog', url: 'https://www.moonb.io/blog' }]}
>
  <section class="section">
    <div class="container">
      <h1 style="margin-bottom: var(--space-10);">Blog</h1>

      {posts.length > 0 ? (
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: var(--space-6);">
          {posts.map((post: any) => (
            <a href={`/blog/${post.slug.current}`} class="card" style="text-decoration: none;">
              <h3 style="margin-bottom: var(--space-3);">{post.title}</h3>
              <p style="font-size: var(--text-small);">{post.metaDescription}</p>
            </a>
          ))}
        </div>
      ) : (
        <p style="color: var(--color-text-muted);">Blog posts coming soon.</p>
      )}
    </div>
  </section>
</BaseLayout>
