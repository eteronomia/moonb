---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getIndustryPages } from '../../lib/sanity';

let industries: any[] = [];
try {
  industries = await getIndustryPages();
} catch {
  // Sanity not yet populated
}
---

<BaseLayout
  title="Industries"
  description="Moonb serves enterprise clients across tech, SaaS, healthcare, fintech, pharma, manufacturing, and more with dedicated creative teams."
  breadcrumbs={[{ name: 'Industries', url: 'https://www.moonb.io/industries' }]}
>
  <section class="section">
    <div class="container">
      <h1 style="margin-bottom: var(--space-6);">Industries We Serve</h1>
      <p style="font-size: var(--text-body-lg); max-width: 600px; margin-bottom: var(--space-12);">
        Dedicated creative teams built for your industry's specific needs.
      </p>

      {industries.length > 0 ? (
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-6);">
          {industries.map((industry: any) => (
            <a href={`/industries/${industry.slug.current}`} class="card" style="text-decoration: none;">
              <h3 style="margin-bottom: var(--space-3);">{industry.title}</h3>
              <p style="font-size: var(--text-small);">{industry.shortDescription || industry.metaDescription}</p>
            </a>
          ))}
        </div>
      ) : (
        <p style="color: var(--color-text-muted);">Industry pages coming from Sanity.</p>
      )}
    </div>
  </section>
</BaseLayout>
