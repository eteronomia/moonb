---
import IndustryLayout from '../../layouts/IndustryLayout.astro';
import { getIndustryPages, getIndustryPage } from '../../lib/sanity';

export async function getStaticPaths() {
  let pages: any[] = [];
  try {
    pages = await getIndustryPages();
  } catch {
    return [];
  }
  return pages.map((page: any) => ({
    params: { slug: page.slug.current },
  }));
}

const { slug } = Astro.params;
let page: any = null;
try {
  page = await getIndustryPage(slug as string);
} catch {
  return Astro.redirect('/industries');
}

if (!page) return Astro.redirect('/industries');

const faqs = (page.faqs || []).map((faq: any) => ({
  question: faq.question,
  answer: typeof faq.answer === 'string'
    ? faq.answer
    : (faq.answer || []).map((block: any) => (block.children || []).map((c: any) => c.text).join('')).join(' '),
}));
---

<IndustryLayout
  title={page.metaTitle || page.title}
  description={page.metaDescription}
  slug={page.slug.current}
  shortDescription={page.shortDescription}
  faqs={faqs}
>
  <section class="section">
    <div class="container">
      <h1 style="margin-bottom: var(--space-6);">{page.mainHeading || page.title}</h1>
      {page.mainDescription && <p style="font-size: var(--text-body-lg); max-width: 640px;">{page.mainDescription}</p>}
    </div>
  </section>
</IndustryLayout>
