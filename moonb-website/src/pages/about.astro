---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="Moonb is a dedicated creative team based in Lisbon, serving US and global enterprise clients with design, video production, and animation."
  breadcrumbs={[{ name: 'About', url: 'https://www.moonb.io/about' }]}
>
  <div class="page-content">
    <section class="section">
      <div class="container container--text">
        <h1 style="margin-bottom: var(--space-8);">About Moonb</h1>
        <p style="font-size: var(--text-body-lg);">
          Moonb is a creative production company that operates as an embedded creative department for enterprise brands. Based in Lisbon, Portugal, we provide dedicated video production, design, motion graphics, and animation teams on a predictable monthly basis.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
