---
import BaseLayout from '../layouts/BaseLayout.astro';
import Testimonials3D from '../components/Testimonials3D.tsx';

// Row 1: scrolls LEFT
const row1 = [
  { name: 'Dell Technologies logo', logo: '/assets/logos/dell.svg' },
  { name: 'Toyota logo', logo: '/assets/logos/toyota.svg' },
  { name: 'Microsoft logo', logo: '/assets/logos/microsoft.svg' },
  { name: 'Politico logo', logo: '/assets/logos/politico.svg', cls: 'hero__marquee-logo--boost' },
  { name: 'OPKO Health logo', logo: '/assets/logos/opko.svg' },
  { name: 'Nestle logo', logo: '/assets/logos/nestle.svg' },
  { name: 'State Street Corporation logo', logo: '/assets/logos/state-street.svg' },
  { name: 'ThriftBooks logo', logo: '/assets/logos/thriftbooks.svg' },
  { name: 'CyberArk logo', logo: '/assets/logos/cyberark.svg' },
  { name: 'BAM Capital Group logo', logo: '/assets/logos/bamcapgroup.svg', cls: 'hero__marquee-logo--lg' },
  { name: 'Jaguar Gene Therapy logo', logo: '/assets/logos/jaguar.svg' },
  { name: 'UC Berkeley logo', logo: '/assets/logos/berkeley.svg' },
];

// Row 2: scrolls RIGHT
const row2 = [
  { name: 'Shionogi logo', logo: '/assets/logos/shionogi.svg' },
  { name: 'GlaxoSmithKline logo', logo: '/assets/logos/gsk.svg' },
  { name: 'Jumo Health logo', logo: '/assets/logos/jumohealth.svg' },
  { name: 'V-nova logo', logo: '/assets/logos/v-nova.svg' },
  { name: 'Unobravo logo', logo: '/assets/logos/unobravo.svg' },
  { name: 'PharmaForceIQ logo', logo: '/assets/logos/pharmaforce.svg' },
  { name: 'Northern Rail logo', logo: '/assets/logos/northern-rail.svg' },
  { name: 'Brainfuse logo', logo: '/assets/logos/brainfuse.svg' },
  { name: 'LHAC logo', logo: '/assets/logos/lhac.svg' },
  { name: 'AcademyOne logo', logo: '/assets/logos/academyone.svg' },
  { name: 'Nottingham logo', logo: '/assets/logos/nottingham.svg' },
];
---

<BaseLayout
  title="Moonb | Dedicated Creative Team for Design & Video Production"
  description="Moonb is a dedicated creative team providing enterprise-grade design, video production, motion graphics, and animation. Each client gets a dedicated Creative Director."
>
  <section class="hero paper-bg" aria-label="Moonb dedicated creative team for enterprise design and video production">
    <div class="hero__inner">
      <!-- Left: Copy -->
      <div class="hero__copy">
        <span class="hero__pill"><span class="hero__pill-dot"></span>Your embedded creative department</span>

        <h1 class="hero__h1">
          <span class="hero__word">Your</span> <span class="hero__word"><span class="highlight">Creative</span></span><br/><span class="hero__word">Services</span> <span class="hero__word">Team</span>
        </h1>

        <p class="hero__sub text-reveal">
          Human-made design and video, delivered weekly by a team that knows your brand inside out.
        </p>

        <div class="hero__buttons text-reveal">
          <a href="#" class="btn btn--purple" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'>Get Started</a>
          <a href="#recent-work" class="btn btn--outline">See Examples</a>
        </div>

        <!-- Social proof strip -->
        <div class="social-proof">
          <div class="social-proof__avatars">
            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=80&h=80&fit=crop&crop=face" alt="" />
            <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=80&h=80&fit=crop&crop=face" alt="" />
            <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=80&h=80&fit=crop&crop=face" alt="" />
            <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=80&h=80&fit=crop&crop=face" alt="" />
            <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=80&h=80&fit=crop&crop=face" alt="" />
            <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=80&h=80&fit=crop&crop=face" alt="" />
            <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=80&h=80&fit=crop&crop=face" alt="" />
            <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=80&h=80&fit=crop&crop=face" alt="" />
          </div>
          <div class="social-proof__text">
            <div class="social-proof__stars">★★★★★</div>
            <span>Trusted by <strong>100+</strong> brands worldwide</span>
          </div>
        </div>
      </div>

      <!-- Right: Video + Badges -->
      <div class="hero__media">
        <div class="hero__video">
          <div style="padding:56.25% 0 0 0;position:relative;">
            <iframe
              src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              style="position:absolute;top:0;left:0;width:100%;height:100%;border-radius:var(--r-sm);"
              title="Moonb creative production showreel featuring design and video work for enterprise clients"
            ></iframe>
          </div>
        </div>

        <div class="hero__badges" role="list" aria-label="Awards and certifications">
          <div class="hero__badge" role="listitem"><img src="/assets/badges/global-award-spring-2024.svg" alt="Clutch Global Award Winner Spring 2024 for video production services" /></div>
          <div class="hero__badge" role="listitem"><img src="/assets/badges/badge-image.svg" alt="Top 100 Stellar video production companies worldwide" /></div>
          <div class="hero__badge" role="listitem"><img src="/assets/badges/clutch-2025.svg" alt="Clutch Top Video Production Company 2025 in arts entertainment and media" /></div>
          <div class="hero__badge" role="listitem"><img src="/assets/badges/2026-badge.svg" alt="Global Leader Top 10 creative production company 2026 by 50Pros" /></div>
        </div>
      </div>
    </div>

    <!-- Client logos marquee: 2 rows, opposite directions -->
    <div class="hero__marquee-wrap" role="region" aria-label="Trusted by enterprise brands worldwide">
      <div class="hero__marquee hero__marquee--left">
        <div class="hero__marquee-track">
          {[...row1, ...row1].map((c) => (
            <span class={`hero__marquee-logo ${c.cls || ''}`}>
              <img src={c.logo} alt={c.name} loading="lazy" />
            </span>
          ))}
        </div>
      </div>
      <div class="hero__marquee hero__marquee--right">
        <div class="hero__marquee-track hero__marquee-track--reverse">
          {[...row2, ...row2].map((c) => (
            <span class={`hero__marquee-logo ${c.cls || ''}`}>
              <img src={c.logo} alt={c.name} loading="lazy" />
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Recent Work: 9×8 Tetris Grid — full viewport, crops on resize -->
  <section class="work" id="recent-work">
    <div class="work__header">
      <h2 class="work__h2">Design and Video That Perform</h2>
      <p class="work__sub">From concept to execution, we deliver high impact design and video content for brands at every stage, from startups and scaleups to enterprise teams.</p>
    </div>

    <div class="work__grid">
      <!-- Row 1: [1×2v] [2×2img] [2×1h] [2×1h] = 1+2+2+2 = 7 -->
      <div class="wc" style="grid-column:1/2;grid-row:1/3"><iframe src="https://player.vimeo.com/video/1176622548?h=db1c34091d&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:2/4;grid-row:1/3"><img src="https://images.unsplash.com/photo-1611162617474-5b21e879e113?w=600&h=600&fit=crop" alt="Social media design" loading="lazy" /></div>
      <div class="wc" style="grid-column:4/6;grid-row:1/2"><iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:6/8;grid-row:1/2"><iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <!-- Row 2: [cont] [cont] [2×1h] [1×1] [1×1] = 0+0+2+1+1+cont+cont = fills with row1 spans -->
      <div class="wc" style="grid-column:4/6;grid-row:2/3"><iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:6/7;grid-row:2/3"><img src="https://images.unsplash.com/photo-1586075010923-2dd4570fb338?w=400&h=400&fit=crop" alt="Packaging" loading="lazy" /></div>
      <div class="wc" style="grid-column:7/8;grid-row:2/3"><img src="https://images.unsplash.com/photo-1626785774573-4b799315345d?w=400&h=400&fit=crop" alt="Ad creative" loading="lazy" /></div>

      <!-- Row 3: [2×1h] [2×2img] [1×1] [1×2v] = 2+2+1+1+cont = need 1 more -->
      <div class="wc" style="grid-column:1/3;grid-row:3/4"><iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:3/5;grid-row:3/5"><img src="https://images.unsplash.com/photo-1634942537034-2531766767d1?w=600&h=600&fit=crop" alt="Brand identity" loading="lazy" /></div>
      <div class="wc" style="grid-column:5/6;grid-row:3/4"><img src="https://images.unsplash.com/photo-1572044162444-ad60f128bdea?w=400&h=400&fit=crop" alt="Logo design" loading="lazy" /></div>
      <div class="wc" style="grid-column:6/7;grid-row:3/5"><iframe src="https://player.vimeo.com/video/1176622548?h=db1c34091d&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:7/8;grid-row:3/4"><img src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=400&h=400&fit=crop" alt="Poster" loading="lazy" /></div>
      <!-- Row 4: [2×1h] [cont] [1×1] [cont] [1×1] = 2+0+1+0+1 + need 3 from spans -->
      <div class="wc" style="grid-column:1/3;grid-row:4/5"><iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:5/6;grid-row:4/5"><img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=400&h=400&fit=crop" alt="Dashboard" loading="lazy" /></div>
      <div class="wc" style="grid-column:7/8;grid-row:4/5"><img src="https://images.unsplash.com/photo-1535016120720-40c646be5580?w=400&h=400&fit=crop" alt="Thumbnail" loading="lazy" /></div>

      <!-- Row 5: [1×1] [1×2v] [2×2img] [2×1h] = 1+1+2+2+cont = need 1 -->
      <div class="wc" style="grid-column:1/2;grid-row:5/6"><img src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=400&h=400&fit=crop" alt="Illustration" loading="lazy" /></div>
      <div class="wc" style="grid-column:2/3;grid-row:5/7"><iframe src="https://player.vimeo.com/video/1176622548?h=db1c34091d&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:3/5;grid-row:5/7"><img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&h=600&fit=crop" alt="Infographic" loading="lazy" /></div>
      <div class="wc" style="grid-column:5/7;grid-row:5/6"><iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:7/8;grid-row:5/6"><img src="https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?w=400&h=400&fit=crop" alt="Web design" loading="lazy" /></div>
      <!-- Row 6: [1×1] [cont] [cont] [1×2v] [2×1h] -->
      <div class="wc" style="grid-column:1/2;grid-row:6/7"><img src="https://images.unsplash.com/photo-1557804506-669a67965ba0?w=400&h=400&fit=crop" alt="Corporate" loading="lazy" /></div>
      <div class="wc" style="grid-column:5/6;grid-row:6/8"><iframe src="https://player.vimeo.com/video/1176622548?h=db1c34091d&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:6/8;grid-row:6/7"><iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>

      <!-- Row 7: [2×1h] [1×2v] [1×2v] [cont] [2×1h] -->
      <div class="wc" style="grid-column:1/3;grid-row:7/8"><iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:3/4;grid-row:7/9"><iframe src="https://player.vimeo.com/video/1176622548?h=db1c34091d&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:4/5;grid-row:7/9"><iframe src="https://player.vimeo.com/video/1176622548?h=db1c34091d&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:6/8;grid-row:7/8"><iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <!-- Row 8: [2×1h] [cont] [cont] [cont] [1×1] [1×1] -->
      <div class="wc" style="grid-column:1/3;grid-row:8/9"><iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" loading="lazy"></iframe></div>
      <div class="wc" style="grid-column:5/6;grid-row:8/9"><img src="https://images.unsplash.com/photo-1559028012-481c04fa702d?w=400&h=400&fit=crop" alt="Banner" loading="lazy" /></div>
      <div class="wc" style="grid-column:6/7;grid-row:8/9"><img src="https://images.unsplash.com/photo-1542744094-3a31f272c490?w=400&h=400&fit=crop" alt="Presentation" loading="lazy" /></div>
      <div class="wc" style="grid-column:7/8;grid-row:8/9"><img src="https://images.unsplash.com/photo-1611532736597-de2d4265fba3?w=400&h=400&fit=crop" alt="Motion" loading="lazy" /></div>
    </div>

    <div class="work__fade"></div>
  </section>

  <!-- "A Better Way" section -->
  <section class="better paper-bg">
    <!-- Heading -->
    <div class="better__header">
      <h2 class="better__h2">A Better Way To Get <span class="highlight">Creative</span> Done</h2>
      <p class="better__sub">No long hiring process and no unreliable freelancers. Your own dedicated team delivering world class design and video every week.</p>
    </div>

    <!-- Big centered video -->
    <div class="better__video-wrap">
      <div class="better__video">
        <iframe src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" style="position:absolute;top:0;left:0;width:100%;height:100%;" title="Moonb showreel"></iframe>
      </div>
    </div>

  </section>

  <!-- Green section with value cards -->
  <section class="green-section">
    <div class="green-section__cards" id="value-cards">
      <div class="better__card better__card--1">
        <div class="better__card-accent"></div>
        <div class="better__card-num">01</div>
        <h3>Better than hiring in house</h3>
        <p>Enjoy all the advantages of hiring in-house without the downsides. No training, no overhead, no hiring costs or long-term commitments. We become an extension of your team.</p>
        <svg class="better__card-deco" viewBox="0 0 80 80"><circle cx="60" cy="20" r="16" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2"/><path d="M10 60 Q40 30 70 65" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2"/></svg>
      </div>
      <div class="better__card better__card--2">
        <div class="better__card-accent"></div>
        <div class="better__card-num">02</div>
        <h3>Beyond agencies & freelancers</h3>
        <p>Say goodbye to delays, scope creep, and endless back-and-forth. Moonb delivers reliable, professional creative, on time, every time.</p>
        <svg class="better__card-deco" viewBox="0 0 80 80"><rect x="10" y="10" width="25" height="25" rx="4" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2" transform="rotate(15 22 22)"/><circle cx="55" cy="55" r="12" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2"/></svg>
      </div>
      <div class="better__card better__card--3">
        <div class="better__card-accent"></div>
        <div class="better__card-num">03</div>
        <h3>Super fast onboarding</h3>
        <p>Sign up and get onboarded to our production platform in minutes. Meet your team on a call and get started the same week.</p>
        <svg class="better__card-deco" viewBox="0 0 80 80"><polygon points="40,5 75,65 5,65" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="2"/></svg>
      </div>
      <div class="better__card better__card--4">
        <div class="better__card-accent"></div>
        <div class="better__card-num">04</div>
        <h3>Quality content creation</h3>
        <p>We identify the core elements of your brand and voice, then translate them into designs and videos. Review, approve, and share.</p>
        <svg class="better__card-deco" viewBox="0 0 80 80"><path d="M10 40 Q25 10 40 40 Q55 70 70 40" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2"/><circle cx="15" cy="60" r="8" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2"/></svg>
      </div>
    </div>
  </section>

  <!-- Resume cream section -->
  <section class="better-cont paper-bg">

    <!-- "A full-time creative team" CTA -->
    <div class="better__cta-section">
      <div class="better__cta-left">
        <h2 class="better__cta-h2">A full-time <span class="highlight">creative</span> team that scales with your needs</h2>
      </div>
      <div class="better__cta-right">
        <p>A dedicated team of designers, motion artists, and directors who plug right into your workflow.</p>
        <div class="better__cta-proof">
          <img src="/assets/badges/clutch-pricing.svg" alt="Clutch" class="better__clutch" />
          <div class="better__cta-avatars">
            <img src="/assets/headshots/young.png" alt="" />
            <img src="/assets/headshots/closeup.png" alt="" />
            <img src="/assets/headshots/smiling.png" alt="" />
            <img src="/assets/headshots/portrait.png" alt="" />
            <img src="/assets/headshots/rene.jpg" alt="" />
            <img src="/assets/headshots/marius.jpg" alt="" />
            <img src="/assets/headshots/diane.jpg" alt="" />
            <img src="/assets/headshots/josh.jpg" alt="" />
          </div>
        </div>
      </div>
    </div>

    <!-- Creative Core pricing card -->
    <div class="better__pricing">
      <div class="better__pricing-card">
        <div class="better__pricing-header">
          <h3>Creative Core</h3>
          <span class="better__pricing-tag">For marketing and creative teams</span>
          <p class="better__pricing-desc">Whether you need a long term creative partner or a single high impact project, Moonb adapts to your needs.</p>
          <a href="#" class="btn btn--purple btn--lg" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'>Request a Quote</a>
          <p class="better__pricing-guarantee">Not loving it after a week? <strong>Get 100% back</strong>, no questions asked.</p>
        </div>
        <div class="better__pricing-features">
          <h4>What's included:</h4>
          <ul>
            <li>Dedicated Creative Director</li>
            <li>Dedicated Creative Team</li>
            <li>Design and Video Production</li>
            <li>Multiple Weekly Deliveries</li>
            <li>Weekly Calls</li>
            <li>24/7 Direct Slack or Teams Chat</li>
            <li>Support for Multiple Brands</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Testimonials vertical marquee -->
    <div class="tc-section">
      <div class="tc-header">
        <span class="tc-pill">Testimonials</span>
        <h2 class="tc-title">What our clients say</h2>
        <p class="tc-sub">Trusted by enterprise teams worldwide.</p>
      </div>
      <Testimonials3D client:visible />
    </div>
  </section>

  <script src="https://player.vimeo.com/api/player.js" is:inline></script>

  <!-- Scroll-triggered card fan-out + testimonial duplication -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Value cards: fade in with rotation on scroll
      const cards = document.querySelectorAll('.better__card');
      if (cards.length) {
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible'); });
        }, { threshold: 0.2 });
        cards.forEach(c => obs.observe(c));
      }

      // 3D testimonials handled by React island
    });
  </script>

  <!-- Add play buttons to all video grid cells -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.wc').forEach(el => {
        if (el.querySelector('iframe')) {
          const btn = document.createElement('div');
          btn.className = 'wc-play';
          el.appendChild(btn);
        }
      });
    });
  </script>
</BaseLayout>


<style is:global>
  /* CSS entrance animations - guaranteed to work without JS */
  .hero__pill, .hero__sub, .hero__buttons, .hero__video, .hero__marquee-wrap {
