---
import BaseLayout from '../layouts/BaseLayout.astro';

const clients = [
  { name: 'Nottingham', logo: '/assets/logos/nottingham.svg' },
  { name: 'Dell Technologies', logo: '/assets/logos/dell.svg' },
  { name: 'PharmaForceIQ', logo: '/assets/logos/pharmaforce.svg' },
  { name: 'Intel', logo: '/assets/logos/intel.svg' },
  { name: 'V-nova', logo: '/assets/logos/v-nova.svg' },
  { name: 'Unobravo', logo: '/assets/logos/unobravo.svg' },
  { name: 'United Way', logo: '/assets/logos/united-way.svg' },
  { name: 'Toyota', logo: '/assets/logos/toyota.svg' },
  { name: 'Thrive Scholars', logo: '/assets/logos/thrive-scholars.svg' },
  { name: 'State Street', logo: '/assets/logos/state-street.svg' },
  { name: 'Shionogi', logo: '/assets/logos/shionogi.svg' },
  { name: 'Politico', logo: '/assets/logos/politico.svg' },
  { name: 'Northern Rail', logo: '/assets/logos/northern-rail.svg' },
  { name: 'Nestle', logo: '/assets/logos/nestle.svg' },
  { name: 'Microsoft', logo: '/assets/logos/microsoft.svg' },
  { name: 'LiveLife', logo: '/assets/logos/livelife.svg' },
  { name: 'GlaxoSmithKline', logo: '/assets/logos/gsk.svg' },
  { name: 'Gnosis', logo: '/assets/logos/gnosis.svg' },
  { name: 'GlobalX', logo: '/assets/logos/globalx.svg' },
  { name: 'CyberArk', logo: '/assets/logos/cyberark.svg' },
];
---

<BaseLayout
  title="Moonb | Dedicated Creative Team for Design & Video Production"
  description="Moonb is a dedicated creative team providing enterprise-grade design, video production, motion graphics, and animation. Each client gets a dedicated Creative Director."
>
  <section class="hero paper-bg">
    <div class="hero__inner">
      <!-- Left: Copy -->
      <div class="hero__copy">
        <span class="hero__pill"><span class="hero__pill-dot"></span>Your embedded creative department</span>

        <h1 class="hero__h1">
          <span class="hero__word">Your</span> <span class="hero__word"><span class="highlight">Creative</span></span><br/><span class="hero__word">Services</span> <span class="hero__word">Team</span>
        </h1>

        <p class="hero__sub text-reveal">
          Human-made design and video, delivered weekly by a team that knows your brand inside out.
        </p>

        <div class="hero__buttons text-reveal">
          <a href="/book-a-demo" class="btn btn--lav">Get Started</a>
          <a href="#recent-work" class="btn btn--green-outline">See Examples</a>
        </div>
      </div>

      <!-- Right: Video + Badges -->
      <div class="hero__media">
        <div class="hero__video">
          <div style="padding:56.25% 0 0 0;position:relative;">
            <iframe
              src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              style="position:absolute;top:0;left:0;width:100%;height:100%;border-radius:var(--r-sm);"
              title="Moonb Showreel"
            ></iframe>
          </div>
        </div>

        <div class="hero__badges">
          <div class="hero__badge"><img src="/assets/badges/global-award-spring-2024.svg" alt="Clutch Global Award Spring 2024" /></div>
          <div class="hero__badge"><img src="/assets/badges/badge-image.svg" alt="Top Video Production Company" /></div>
          <div class="hero__badge"><img src="/assets/badges/clutch-2025.svg" alt="Clutch 2025 Award" /></div>
          <div class="hero__badge"><img src="/assets/badges/2026-badge.svg" alt="2026 Award Badge" /></div>
        </div>
      </div>
    </div>

    <!-- Client logos marquee -->
    <div class="hero__marquee">
      <div class="hero__marquee-track">
        {[...clients, ...clients].map((c) => (
          <span class="hero__marquee-logo">
            <img src={c.logo} alt={c.name} loading="lazy" />
          </span>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script src="https://player.vimeo.com/api/player.js"></script>

<style is:global>
  /* CSS entrance animations - guaranteed to work without JS */
  .hero__pill, .hero__sub, .hero__buttons, .hero__video, .hero__marquee {
    animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero__pill    { animation-delay: 0.1s; }
  .hero__sub     { animation-delay: 0.55s; }
  .hero__buttons { animation-delay: 0.65s; }
  .hero__video   { animation-delay: 0.15s; }
  .hero__marquee { animation-delay: 0.8s; }

  /* Word-by-word H1 reveal */
  .hero__word {
    display: inline-block;
    overflow: hidden;
  }
  .hero__word {
    animation: wordReveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero__word:nth-child(1) { animation-delay: 0.15s; }
  .hero__word:nth-child(2) { animation-delay: 0.25s; }
  .hero__word:nth-child(3) { animation-delay: 0.35s; }
  .hero__word:nth-child(4) { animation-delay: 0.45s; }

  /* Highlighter sweep animates in after the word lands */
  .highlight::after {
    animation: highlightSweep 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.55s;
  }

  .hero__badge {
    animation: fadeScaleUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero__badge:nth-child(1) { animation-delay: 0.5s; }
  .hero__badge:nth-child(2) { animation-delay: 0.56s; }
  .hero__badge:nth-child(3) { animation-delay: 0.62s; }
  .hero__badge:nth-child(4) { animation-delay: 0.68s; }

  .nav__bar {
    animation: fadeSlideDown 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.05s;
  }

  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeSlideDown {
    from { opacity: 0; transform: translateY(-14px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeScaleUp {
    from { opacity: 0; transform: translateY(12px) scale(0.92); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes wordReveal {
    from { opacity: 0; transform: translateY(100%) rotateX(-20deg); filter: blur(4px); }
    to { opacity: 1; transform: translateY(0) rotateX(0); filter: blur(0); }
  }
  @keyframes highlightSweep {
    from { transform: scaleX(0); transform-origin: left; }
    to { transform: scaleX(1); transform-origin: left; }
  }
</style>

<style>
  .hero {
    background: var(--cream);
    padding: calc(56px + var(--s-16)) 0 0;
    border-radius: 0 0 var(--r) var(--r);
    overflow: hidden;
  }

  .hero__inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--s-6);
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: var(--s-12);
    align-items: start;
  }

  /* --- Pill tag --- */
  .hero__pill {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-size: 13px;
    font-weight: 400;
    color: var(--muted);
    margin-bottom: var(--s-6);
    padding: 6px 16px;
    border-radius: var(--r-pill);
    background: rgba(26,60,46,0.07);
    border: 1px solid rgba(26,60,46,0.12);
    color: var(--green);
  }

  .hero__pill-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--teal);
    display: inline-block;
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  /* --- Headline --- */
  .hero__h1 {
    font-size: clamp(2.75rem, 5.5vw, 4.2rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.035em;
    margin-bottom: var(--s-6);
    color: var(--text);
  }

  .hero__sub {
    font-size: 16px;
    line-height: 1.7;
    color: var(--muted);
    max-width: 380px;
    margin-bottom: var(--s-8);
    font-weight: 400;
  }

  .hero__buttons { display: flex; gap: var(--s-4); flex-wrap: wrap; }

  /* --- Video --- */
  .hero__media { display: flex; flex-direction: column; gap: var(--s-6); }

  .hero__video {
    border-radius: var(--r-sm);
    overflow: hidden;
    box-shadow: var(--sh-lg);
    background: var(--cream-dark);
  }

  /* --- Badges: aligned under video, equal size, no container box --- */
  .hero__badges {
    display: flex;
    gap: var(--s-4);
    justify-content: flex-start;
    align-items: center;
  }

  .hero__badge {
    width: auto;
    height: auto;
    background: none;
    border: none;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero__badge img {
    height: 56px;
    width: auto;
    object-fit: contain;
  }

  /* --- Marquee --- */
  .hero__marquee {
    overflow: hidden;
    padding: var(--s-12) 0 var(--s-10);
    border-top: 1px solid rgba(26,26,26,0.06);
    margin-top: var(--s-16);
  }

  .hero__marquee-track {
    display: flex;
    gap: var(--s-16);
    animation: marquee 50s linear infinite;
    width: max-content;
  }
  .hero__marquee-track:hover { animation-play-state: paused; }

  .hero__marquee-logo {
    display: flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .hero__marquee-logo img {
    height: 20px;
    width: auto;
    opacity: 0.55;
    filter: brightness(0) saturate(100%) invert(19%) sepia(15%) saturate(1200%) hue-rotate(100deg) brightness(95%);
    transition: opacity 0.3s;
  }
  .hero__marquee-logo img:hover {
    opacity: 0.85;
  }
  .hero__marquee-logo-text {
    font-family: var(--font-h);
    font-weight: 500;
    font-size: 14px;
    color: var(--text);
    opacity: 0.18;
    transition: opacity 300ms ease;
  }
  .hero__marquee-logo:hover { opacity: 0.45; }

  @keyframes marquee { to { transform: translateX(-50%); } }

  @media (max-width: 860px) {
    .hero__inner { grid-template-columns: 1fr; gap: var(--s-8); }
    .hero__badges { justify-content: flex-start; }
    .hero__h1 { font-size: 2.5rem; }
  }
</style>
