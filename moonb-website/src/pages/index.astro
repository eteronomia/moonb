---
import BaseLayout from '../layouts/BaseLayout.astro';

const clients = ['Nottingham', 'Dell Technologies', 'PharmaForceIQ', 'Intel', 'V-nova', 'Unobravo', 'United Way', 'Toyota', 'Thrive Scholars', 'State Street', 'Shionogi', 'Politico', 'Northern Rail', 'Nestle', 'Microsoft', 'LiveLife', 'GlaxoSmithKline', 'Gnosis', 'GlobalX', 'CyberArk'];
---

<BaseLayout
  title="Moonb | Dedicated Creative Team for Design & Video Production"
  description="Moonb is a dedicated creative team providing enterprise-grade design, video production, motion graphics, and animation. Each client gets a dedicated Creative Director."
>
  <!-- ==================== HERO ==================== -->
  <section class="hero paper-bg">
    <div class="hero__inner">
      <!-- Left: Copy -->
      <div class="hero__copy">
        <div class="hero__tag">
          <span class="hero__tag-dot"></span>
          Your embedded creative department
        </div>

        <h1 class="hero__h1 text-reveal">
          Your <span class="highlight">Creative</span><br/>Services Team
        </h1>

        <p class="hero__sub text-reveal">
          Human-made design and video, delivered weekly by a team that knows your brand inside out.
        </p>

        <div class="hero__buttons text-reveal">
          <a href="/book-a-demo" class="btn btn--lav">Get Started</a>
          <a href="#recent-work" class="btn btn--outline">See Examples</a>
        </div>

        <!-- Decorative arrow -->
        <svg class="hero__arrow" width="140" height="90" viewBox="0 0 140 90" fill="none">
          <path d="M12 12 C 40 70, 90 70, 115 35" stroke="var(--text)" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-dasharray="4 6"/>
          <path d="M107 27 L115 35 L105 38" stroke="var(--text)" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Right: Video + Badges -->
      <div class="hero__media">
        <div class="hero__video">
          <div style="padding:56.25% 0 0 0;position:relative;">
            <iframe
              src="https://player.vimeo.com/video/1084258404?h=bf1bb4d67b&badge=0&autopause=0&player_id=0&app_id=58479"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              style="position:absolute;top:0;left:0;width:100%;height:100%;border-radius:var(--r-sm);"
              title="Moonb Showreel"
            ></iframe>
          </div>
        </div>

        <!-- Square badge placeholders -->
        <div class="hero__badges">
          <div class="hero__badge"></div>
          <div class="hero__badge"></div>
          <div class="hero__badge"></div>
          <div class="hero__badge"></div>
        </div>
      </div>
    </div>

    <!-- Client logos marquee -->
    <div class="hero__marquee">
      <div class="hero__marquee-track">
        {[...clients, ...clients].map((name) => (
          <span class="hero__marquee-logo">{name}</span>
        ))}
      </div>
    </div>

    <!-- Green accent strip at bottom -->
    <div class="hero__green-strip">
      <div class="container" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--s-4);">
        <p style="color:var(--cream);font-weight:500;font-size:15px;opacity:0.9;">Trusted by enterprise brands worldwide</p>
        <a href="/book-a-demo" class="btn btn--outline-light" style="font-size:13px;padding:8px 20px;border-color:rgba(242,237,228,0.3);color:var(--cream);">Book a Demo →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Vimeo player script -->
<script src="https://player.vimeo.com/api/player.js"></script>

<!-- Text reveal animations -->
<script>
  // Simple IntersectionObserver for text reveals
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.text-reveal').forEach(el => {
    observer.observe(el);
  });

  // Stagger the reveals
  document.querySelectorAll('.text-reveal').forEach((el, i) => {
    (el as HTMLElement).style.transitionDelay = `${i * 0.12}s`;
  });
</script>

<style>
  .hero {
    background: var(--cream);
    padding: calc(var(--nav-h) + var(--s-16)) 0 0;
    border-radius: 0 0 var(--r) var(--r);
    overflow: hidden;
  }

  .hero__inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--s-6);
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: var(--s-12);
    align-items: start;
  }

  /* --- Tag --- */
  .hero__tag {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    margin-bottom: var(--s-6);
    letter-spacing: 0.02em;
  }

  .hero__tag-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--teal);
    display: inline-block;
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  /* --- Headline --- */
  .hero__h1 {
    font-size: clamp(2.75rem, 5.5vw, 4.2rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    margin-bottom: var(--s-6);
    color: var(--text);
  }

  .hero__sub {
    font-size: 16px;
    line-height: 1.7;
    color: var(--muted);
    max-width: 380px;
    margin-bottom: var(--s-8);
  }

  .hero__buttons {
    display: flex;
    gap: var(--s-4);
    flex-wrap: wrap;
  }

  .hero__arrow {
    margin-top: var(--s-12);
    opacity: 0.2;
  }

  /* --- Video --- */
  .hero__media {
    display: flex;
    flex-direction: column;
    gap: var(--s-6);
  }

  .hero__video {
    border-radius: var(--r-sm);
    overflow: hidden;
    box-shadow: var(--sh-lg);
    background: var(--cream-dark);
  }

  /* --- Square badges --- */
  .hero__badges {
    display: flex;
    gap: var(--s-3);
    justify-content: flex-end;
  }

  .hero__badge {
    width: 72px;
    height: 72px;
    border-radius: 14px;
    background: var(--cream-dark);
    border: 1px solid rgba(26,26,26,0.06);
    transition: transform 200ms ease;
  }

  .hero__badge:hover {
    transform: translateY(-2px);
  }

  /* --- Marquee --- */
  .hero__marquee {
    overflow: hidden;
    padding: var(--s-12) 0;
    border-top: 1px solid rgba(26,26,26,0.06);
    margin-top: var(--s-16);
  }

  .hero__marquee-track {
    display: flex;
    gap: var(--s-16);
    animation: marquee 50s linear infinite;
    width: max-content;
  }

  .hero__marquee-track:hover { animation-play-state: paused; }

  .hero__marquee-logo {
    font-family: var(--font-h);
    font-weight: 600;
    font-size: 14px;
    color: var(--text);
    white-space: nowrap;
    opacity: 0.18;
    transition: opacity 300ms ease;
  }

  .hero__marquee-logo:hover { opacity: 0.45; }

  @keyframes marquee {
    to { transform: translateX(-50%); }
  }

  /* --- Green accent strip --- */
  .hero__green-strip {
    background: var(--green);
    padding: var(--s-5) 0;
    border-radius: var(--r-sm) var(--r-sm) 0 0;
    margin-top: var(--s-4);
  }

  /* --- Button outline light --- */
  .btn--outline-light {
    background: transparent;
    border: 1.5px solid rgba(242,237,228,0.3);
    color: var(--cream);
    border-radius: var(--r-pill);
    font-size: 13px;
  }
  .btn--outline-light:hover { background: rgba(242,237,228,0.06); }

  /* --- Mobile --- */
  @media (max-width: 860px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--s-8);
    }
    .hero__arrow { display: none; }
    .hero__badges { justify-content: flex-start; }
    .hero__h1 { font-size: 2.5rem; }
  }
</style>
