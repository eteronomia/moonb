---
const links = [
  { label: 'How it works', href: '#how-it-works' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'Recent work', href: '#recent-work' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Blog', href: '/blog' },
];
---

<nav class="nav">
  <div class="nav__bar">
    <a href="/" class="nav__logo" aria-label="Moonbee homepage">
      <img src="/assets/logos/moonbee-icon.svg" alt="Moonbee logo" class="nav__logo-icon" width="32" height="32" />
      <span class="nav__logo-text">moonb<span style="color:var(--lav-dark)">ee</span></span>
    </a>

    <div class="nav__center">
      {links.map((link) => (
        <a href={link.href} class="nav__link">{link.label}</a>
      ))}
    </div>

    <a href="#" class="nav__cta" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'>Book a Demo</a>

    <button class="nav__toggle" aria-label="Menu" id="nav-toggle">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="nav__mobile" id="mobile-menu">
  {links.map((link) => (
    <a href={link.href} class="nav__mobile-link">{link.label}</a>
  ))}
  <a href="#" class="nav__cta" style="margin-top:8px;width:100%;justify-content:center;" data-cal-link="team/moonb/book-a-demo" data-cal-namespace="book-a-demo" data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'>Book a Demo</a>
</div>

<style>
  .nav {
    position: fixed;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--z-nav);
    width: calc(100% - 32px);
    max-width: 1040px;
  }

  .nav__bar {
    display: flex;
    align-items: center;
    padding: 10px 12px 10px 20px;
    background: rgba(242, 237, 228, 0.65);
    backdrop-filter: blur(24px) saturate(1.3);
    -webkit-backdrop-filter: blur(24px) saturate(1.3);
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.35);
    box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04), inset 0 1px 1px rgba(255,255,255,0.7), inset 0 -1px 1px rgba(255,255,255,0.15);
  }

  .nav__logo { display:flex; align-items:center; gap:6px; margin-right:12px; }
  .nav__logo-icon { width:28px; height:28px; object-fit:contain; }
  .nav__logo-text {
    font-family: var(--font-h);
    font-weight: 600;
    font-size: 17px;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .nav__center {
    display: flex;
    align-items: center;
    gap: 2px;
    margin: 0 auto;
  }

  .nav__link {
    font-size: 14px;
    font-weight: 400;
    color: var(--text);
    padding: 7px 14px;
    border-radius: 10px;
    transition: background 150ms ease;
    white-space: nowrap;
  }
  .nav__link:hover { background: rgba(26,26,26,0.05); }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    padding: 9px 22px;
    border-radius: 10px;
    background: var(--yellow);
    color: var(--text);
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
    transition: all 300ms cubic-bezier(0.16, 1, 0.3, 1);
    border: 1.5px solid rgba(26,26,26,0.06);
    position: relative;
    overflow: hidden;
  }
  .nav__cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    transform: translateX(-100%);
    transition: none;
  }
  .nav__cta:hover {
    background: var(--yellow-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(255,214,0,0.35);
  }
  .nav__cta:hover::before {
    animation: shimmer 0.6s ease forwards;
  }
  @keyframes shimmer {
    to { transform: translateX(100%); }
  }

  .nav__toggle { display:none; flex-direction:column; gap:4px; padding:8px; margin-left:auto; }
  .nav__toggle span { display:block; width:18px; height:2px; background:var(--text); border-radius:1px; }

  .nav__mobile {
    display: none;
    position: fixed;
    top: 72px; left: 16px; right: 16px;
    z-index: calc(var(--z-nav) - 1);
    background: var(--cream);
    border-radius: 16px;
    padding: 16px;
    flex-direction: column;
    gap: 2px;
    box-shadow: 0 24px 48px rgba(14,14,14,0.12);
    border: 1px solid rgba(26,26,26,0.06);
  }
  .nav__mobile.is-open { display: flex; }
  .nav__mobile-link {
    display:block; padding:12px 16px; font-size:15px; font-weight:400;
    color:var(--text); border-radius:10px;
  }
  .nav__mobile-link:hover { background:rgba(26,26,26,0.04); }

  @media (max-width:860px) {
    .nav__center { display:none; }
    .nav__cta { display:none; }
    .nav__toggle { display:flex; }
  }
</style>

<script>
  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('is-open');
  });
  document.getElementById('mobile-menu')?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => document.getElementById('mobile-menu')?.classList.remove('is-open'));
  });
</script>
