---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import { articleSchema } from '../lib/schema';

interface Props {
  title: string;
  description?: string;
  publishDate: string;
  author?: string;
  slug: string;
  heroImage?: string;
  noindex?: boolean;
  ogImage?: string;
}

const { title, description, publishDate, author, slug, heroImage, noindex, ogImage } = Astro.props;

const schemas = [
  articleSchema({
    title,
    metaDescription: description,
    publishDate,
    author,
    slug: { current: slug },
    heroImage,
  }),
];

const breadcrumbs = [
  { name: 'Blog', url: 'https://www.moonb.io/blog' },
  { name: title, url: `https://www.moonb.io/blog/${slug}` },
];
---

<BaseLayout
  title={title}
  description={description}
  noindex={noindex}
  ogImage={ogImage}
  schemas={schemas}
  breadcrumbs={breadcrumbs}
>
  <article class="container container--text" style="padding-block: var(--space-12);">
    <Breadcrumbs crumbs={[{ name: 'Home', url: '/' }, { name: 'Blog', url: '/blog' }, { name: title, url: `/blog/${slug}` }]} />

    <header style="margin-bottom: var(--space-10);">
      <h1 style="margin-bottom: var(--space-4);">{title}</h1>
      <time datetime={publishDate} style="font-size: var(--text-small); color: var(--color-text-muted);">
        {new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>

    <div class="blog-content">
      <slot />
    </div>
  </article>
</BaseLayout>
